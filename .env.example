# Supabase — get these from your project's Settings > API page
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct Postgres connection — used ONLY by the migration runner (npm run db:migrate).
# Settings > Database > Connection string > URI. Use port 5432 (session/direct),
# not the 6543 transaction pooler — DDL needs a session connection.
SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# Resend — get your API key from resend.com/api-keys
RESEND_API_KEY=re_your_key_here
# The "from" address for outgoing emails (must be a verified domain in Resend)
RESEND_FROM_EMAIL=plans@yourdomain.com

# App URL — used for constructing plan links in emails
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron job secret — prevents unauthorized calls to /api/cron/sunday-email
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# Stripe — get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Safe to expose to the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Price IDs — create a product in Stripe Dashboard > Products, then add two
# recurring prices ($7/month and $60/year) and paste their IDs below.
# Local webhook testing: stripe listen --forward-to localhost:3000/api/stripe/webhook
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_your_monthly_id_here
NEXT_PUBLIC_STRIPE_ANNUAL_PRICE_ID=price_your_annual_id_here
